# 토스페이먼츠 결제위젯 키
# 이 파일을 복사해 .env 로 만든 뒤 값을 채우세요:  cp .env.example .env
# 키 확인: https://developers.tosspayments.com  (개발자센터 > API 키 > 결제위젯 연동 키)
#
# ⚠️ EXPO_PUBLIC_ 접두사가 붙은 값은 앱 번들에 그대로 노출됩니다.
#    시크릿키를 클라이언트에서 쓰는 건 테스트 전용입니다.
#    운영 환경에서는 시크릿키를 서버에만 두고 승인(confirm) API를 서버에서 호출하세요.

# 결제위젯 연동 키 > 클라이언트 키
EXPO_PUBLIC_TOSS_CLIENT_KEY=test_gck_docs_Ovk5rk1EwkEbP0W43n07xlzm

# 결제위젯 연동 키 > 시크릿 키 (테스트 전용 클라이언트 승인용)
EXPO_PUBLIC_TOSS_SECRET_KEY=test_gsk_docs_OaPz8L5KdmQXkzRz3y47BMw6

# ── Supabase (이메일 인증/실제 메일 발송) ──
# https://supabase.com/dashboard → 프로젝트 → Project Settings > API
# URL/anon key 는 공개돼도 안전합니다. (Row Level Security 로 보호)
EXPO_PUBLIC_SUPABASE_URL=https://YOUR-PROJECT.supabase.co
EXPO_PUBLIC_SUPABASE_ANON_KEY=YOUR-ANON-PUBLIC-KEY
